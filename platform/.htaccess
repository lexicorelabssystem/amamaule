# Plataforma AMA - Proteccion anti-acceso directo via Apache/XAMPP
# Este archivo bloquea el acceso directo a la carpeta platform/ desde el navegador
# cuando esta dentro del document root de XAMPP. En produccion el virtual host
# apuntara directamente a platform/public/, por lo que este archivo no estara expuesto.

<IfModule mod_authz_core.c>
    Require all denied
</IfModule>
<IfModule !mod_authz_core.c>
    Order deny,allow
    Deny from all
</IfModule>
